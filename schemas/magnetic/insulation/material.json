{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/magnetic/insulation/material.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "insulation/material",
    "description": "A material for insulation",
    "type": "object",
    "properties": {
        "composition": {
            "description": "The composition of a insulation material",
            "type": "string"
        },
        "name": {
            "description": "The name of a insulation material",
            "type": "string"
        },
        "aliases": {
            "description": "Alternative names of the material",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "manufacturerInfo": {
            "$ref": "../../utils.json#/$defs/manufacturerInfo"
        },
        "dielectricStrength":{
            "type": "array",
            "items": {
                "$ref": "#/$defs/dieletricStrengthPoint"
            },
            "minItems": 1
        },
        "relativePermittivity": {
            "description": "The dielectric constant of the insulation material",
            "type": "number",
            "exclusiveMinimum": 0
        },
        "thermalConductivity": {
            "description": "The thermal conductivity of the insulation material, in W / (m * K)",
            "type": "number",
            "exclusiveMinimum": 0
        },
        "specificHeat": {
            "description": "The specific heat of the insulation material, in J / (Kg * K)",
            "type": "number",
            "exclusiveMinimum": 0
        },
        "temperatureClass": {
            "description": "The temperature class of the insulation material, in Celsius",
            "type": "number",
            "exclusiveMinimum": 0
        },
        "meltingPoint": {
            "description": "The melting temperature of the insulation material, in Celsius",
            "type": "number",
            "exclusiveMinimum": 0
        },
        "resistivity": {
            "description": "Volume resistivity per IEC 60093. Unit: ohm metre (Ohm.m).",
            "type": "array",
            "items": {
                "$ref": "../../utils.json#/$defs/resistivityPoint"
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "surfaceResistivity": {
            "description": "Surface resistivity per IEC 60093. Unit: ohm per square (Ohm/sq). Relevant to tracking and creepage assessment per IEC 60112 / IEC 60664-1.",
            "type": "array",
            "items": {
                "$ref": "../../utils.json#/$defs/resistivityPoint"
            },
            "minItems": 1,
            "uniqueItems": true
        }
    },
    "required": ["name", "dielectricStrength"],

    "$defs": {
        "dieletricStrengthPoint": {
            "description": "data for describing one point of dieletric strength",
            "type": "object",
            "properties": {
                "value": {
                    "description": "Dieletric strength value, in V / m",
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "thickness": {
                    "description": "Thickness of the material",
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "temperature": {
                    "description": "Temperature for the field value, in Celsius.",
                    "type": "number"
                },
                "humidity": {
                    "description": "Humidity for the field value, in proportion over 1",
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            },
            "required": ["value"]
        }
    }
}