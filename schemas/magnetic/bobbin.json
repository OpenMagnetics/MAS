{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/magnetic/bobbin.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "bobbin",
    "description": "Description of a bobbin (the insulating former on which one or more windings are arranged). The term is industry-conventional; an IEV entry is being proposed by PSMA. See docs/normative-references.md.",
    "type": "object",
    "properties": {
        "name": {
            "description": "Name of the bobbin.",
            "type": "string"
        },
        "manufacturerInfo": {
            "$ref": "../utils.json#/$defs/manufacturerInfo"
        },
        "distributorsInfo": {
            "description": "List of distributors of this bobbin.",
            "type": "array",
            "items": {
                "$ref": "../utils.json#/$defs/distributorInfo"
            },
            "uniqueItems": false
        },
        "functionalDescription": {
            "description": "Bobbin data described in functional terms, in a form suitable for analytical models.",
            "type": "object",
            "title": "bobbinFunctionalDescription",
            "properties": {
                "type": {
                    "description": "Whether the bobbin is a standard catalogue part or a custom design.",
                    "type": "string",
                    "enum": [
                        "standard",
                        "custom"
                    ]
                },
                "family": {
                    "description": "Bobbin family, named after the core shape family it is intended to fit. See IEC 62317 / IEC 63093.",
                    "title": "bobbinFamily",
                    "type": "string",
                    "enum": [
                        "u",
                        "e",
                        "etd",
                        "er",
                        "p",
                        "rm",
                        "ep",
                        "pm",
                        "el",
                        "pq",
                        "efd",
                        "ec",
                        "t"
                    ]
                },
                "shape": {
                    "description": "Name of the core shape this bobbin is matched to.",
                    "type": "string"
                },
                "familySubtype": {
                    "description": "Subtype of the shape, where more than one variant exists in the family.",
                    "type": "string"
                },
                "material": {
                    "oneOf": [
                        {
                            "$ref": "./insulation/material.json"
                        },
                        {
                            "description": "Name of the material used in the bobbin.",
                            "type": "string"
                        }
                    ]
                },
                "dimensions": {
                    "description": "Bobbin dimensions. Keys are the dimension labels defined in IEC 62317 / IEC 63093 for the parent core shape.",
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "../utils.json#/$defs/dimension"
                    }
                },
                "pinout": {
                    "$ref": "#/$defs/pinout"
                },
                "connections": {
                    "description": "List of connections between windings and pins",
                    "type": "array",
                    "items": {
                        "title": "pinWindingConnection",
                        "type": "object",
                        "properties": {
                            "pin": {
                                "description": "The name of the connected pin",
                                "type": "string"
                            },
                            "winding": {
                                "description": "The name of the connected winding",
                                "type": "string"
                            }
                        }
                    },
                    "minItems": 0,
                    "uniqueItems": true
                }
            },
            "required": [
                "type",
                "family",
                "shape",
                "dimensions"
            ]
        },
        "processedDescription": {
            "type": "object",
            "title": "coreBobbinProcessedDescription",
            "properties": {
                "wallThickness": {
                    "description": "The thickness of the walls that hold the wire on both sides of the column",
                    "type": "number",
                    "minimum": 0
                },
                "columnThickness": {
                    "description": "The thickness of the central column wall, where the wire is wound, in the X axis",
                    "type": "number",
                    "minimum": 0
                },
                "columnDepth": {
                    "description": "The depth of the central column wall, including thickness, in the z axis",
                    "type": "number",
                    "minimum": 0
                },
                "columnWidth": {
                    "description": "The width of the central column wall, including thickness, in the x axis",
                    "type": "number",
                    "minimum": 0
                },
                "columnShape": {
                    "$ref": "../utils.json#/$defs/columnShape"
                },
                "windingWindows": {
                    "description": "List of winding windows, all elements in the list must be of the same type",
                    "title": "windingWindows",
                    "oneOf": [
                        {
                            "description": "List of rectangular winding windows",
                            "type": "array",
                            "items": {
                                "$ref": "./core.json#/$defs/rectangularWindingWindow"
                            },
                            "minItems": 1,
                            "uniqueItems": false
                        },
                        {
                            "description": "List of radial winding windows",
                            "type": "array",
                            "items": {
                                "$ref": "./core.json#/$defs/radialWindingWindow"
                            },
                            "minItems": 1,
                            "uniqueItems": false
                        }
                    ]
                },
                "pins": {
                    "description": "List of pins, geometrically defining how and where it is",
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/pin"
                    },
                    "minItems": 0,
                    "uniqueItems": true
                },
                "coordinates": {
                    "description": "The coordinates of the center of the bobbin central wall, where the wires are wound, referred to the center of the main column.",
                    "$ref": "../utils.json#/$defs/coordinates"
                }
            },
            "required": [
                "columnShape",
                "wallThickness",
                "columnThickness",
                "columnDepth",
                "windingWindows"
            ]
        }
    },
    "anyOf": [
        {
            "required": [
                "functionalDescription"
            ]
        },
        {
            "required": [
                "processedDescription"
            ]
        }
    ],
    "$defs": {
        "pin": {
            "description": "Data describing one pin in a bobbin",
            "title": "pin",
            "type": "object",
            "properties": {
                "name": {
                    "description": "Name given to the pin",
                    "type": "string"
                },
                "shape": {
                    "description": "The shape of the pin",
                    "title": "pinShape",
                    "type": "string",
                    "enum": [
                        "round",
                        "rectangular",
                        "irregular"
                    ]
                },
                "type": {
                    "description": "Type of pin",
                    "type": "string",
                    "enum": [
                        "smd",
                        "tht"
                    ]
                },
                "rotation": {
                    "description": "The rotation of the pin, default is vertical",
                    "$ref": "../utils.json#/$defs/rotation"
                },
                "dimensions": {
                    "description": "Dimensions of the rectangle defining the pin",
                    "$ref": "../utils.json#/$defs/dimensions"
                },
                "coordinates": {
                    "description": "The coordinates of the center of the pin, referred to the center of the main column",
                    "$ref": "../utils.json#/$defs/coordinates"
                }
            },
            "required": [
                "shape",
                "type",
                "dimensions"
            ]
        },
        "pinout": {
            "description": "Data describing the pinout of a bobbin",
            "title": "pinout",
            "type": "object",
            "properties": {
                "pitch": {
                    "oneOf": [
                        {
                            "description": "The distance between pins, per row, by pin order",
                            "type": "array",
                            "items": {
                                "type": "number"
                            }
                        },
                        {
                            "description": "The distance between pins, common for all pins",
                            "type": "number"
                        }
                    ]
                },
                "centralPitch": {
                    "description": "The distance between central pins",
                    "type": "number"
                },
                "rowDistance": {
                    "description": "The distance between a row of pins and the center of the bobbin",
                    "type": "number"
                },
                "numberRows": {
                    "description": "The number of rows of a bobbin, typically 2",
                    "type": "integer",
                    "default": 2
                },
                "numberPins": {
                    "description": "The number of pins",
                    "type": "integer"
                },
                "numberPinsPerRow": {
                    "description": "List of pins per row",
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "pinDescription": {
                    "$ref": "#/$defs/pin"
                }
            },
            "required": [
                "pitch",
                "rowDistance",
                "numberPins",
                "pinDescription"
            ]
        }
    }
}
