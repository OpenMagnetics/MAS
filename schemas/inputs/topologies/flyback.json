{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/inputs/topologies/flyback.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "flyback",
    "description": "The description of a Flyback converter excitation",
    "type": "object",
    "properties": {
        "inputVoltage": {
            "description": "The input voltage of the flyback",
            "$ref": "../../utils.json#/$defs/dimensionWithTolerance"
        },
        "diodeVoltageDrop": {
            "description": "The voltage drop on the diode",
            "type": "number"
        },
        "maximumDrainSourceVoltage": {
            "description": "The maximum drain-source voltage in the selected switch",
            "type": "number"
        },
        "maximumDutyCycle": {
            "description": "The maximum duty cycle in the selected switch",
            "type": "number"
        },
        "currentRippleRatio": {
            "description": "The maximum current ripple allowed in the output",
            "type": "number"
        },
        "efficiency": {
            "description": "The target efficiency",
            "type": "number",
            "default": 0.95
        },
        "operatingPoints": {
            "description": "A list of operating points",
            "type": "array",
            "items": {
                "$ref": "#/$defs/flybackOperatingPoint"
            },
            "minItems": 1
        }
    },
    "required": [
        "inputVoltage",
        "diodeVoltageDrop",
        "currentRippleRatio",
        "efficiency",
        "operatingPoints"
    ],
    "$defs": {
        "flybackModes": {
            "description": "The conduction mode of the Flyback",
            "title": "flybackModes",
            "type": "string",
            "enum": [
                "continuousConductionMode",
                "discontinuousConductionMode",
                "quasiResonantMode",
                "boundaryModeOperation"
            ]
        },
        "flybackOperatingPoint": {
            "description": "The description of one flyback operating point",
            "title": "flybackOperatingPoint",
            "allOf": [
                {
                    "$ref": "../../utils.json#/$defs/baseOperatingPoint"
                },
                {
                    "type": "object",
                    "properties": {
                        "mode": {
                            "description": "The mode of the operating point.",
                            "$ref": "#/$defs/flybackModes"
                        }
                    }
                }
            ]
        }
    }
}
