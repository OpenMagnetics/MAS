{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/inputs/topologies/flybuck.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "flybuck",
    "description": "The description of a Flybuck converter excitation",
    "type": "object",
    "properties": {
        "inputVoltage": {
            "description": "The input voltage of the flybuck",
            "$ref": "../../utils.json#/$defs/dimensionWithTolerance"
        },
        "diodeVoltageDrop": {
            "description": "The voltage drop on the diode",
            "type": "number"
        },
        "operatingPoints": {
            "description": "A list of operating points",
            "type": "array",
            "items": {
                "$ref": "#/$defs/flybuckOperatingPoint"
            },
            "minItems": 1
        }
    },
    "required": [
        "inputVoltage",
        "diodeVoltageDrop",
        "operatingPoints"
    ],
    "$defs": {
        "flybuckOperatingPoint": {
            "description": "The description of one flybuck operating point",
            "title": "flybuckOperatingPoint",
            "allOf": [
                {
                    "$ref": "../../utils.json#/$defs/baseOperatingPoint"
                }
            ]
        }
    }
}
