{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/inputs/topologies/cllcResonant.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "cllcResonant",
    "description": "The description of a CLLC Bidirectional Resonant converter excitation",
    "type": "object",
    "properties": {
        "inputVoltage": {
            "description": "The input voltage (HV side) of the CLLC converter",
            "$ref": "../../utils.json#/$defs/dimensionWithTolerance"
        },
        "minSwitchingFrequency": {
            "description": "The minimum switching frequency for regulation",
            "type": "number"
        },
        "maxSwitchingFrequency": {
            "description": "The maximum switching frequency for regulation",
            "type": "number"
        },
        "qualityFactor": {
            "description": "The quality factor of the resonant tank",
            "type": "number",
            "default": 0.5
        },
        "efficiency": {
            "description": "The target efficiency",
            "type": "number",
            "default": 0.97
        },
        "symmetricDesign": {
            "description": "Whether to use symmetric resonant tank design",
            "type": "boolean",
            "default": true
        },
        "bidirectional": {
            "description": "Whether the converter operates in bidirectional mode",
            "type": "boolean",
            "default": true
        },
        "operatingPoints": {
            "description": "A list of operating points",
            "type": "array",
            "items": {
                "$ref": "#/$defs/cllcOperatingPoint"
            },
            "minItems": 1
        }
    },
    "required": [
        "inputVoltage",
        "minSwitchingFrequency",
        "maxSwitchingFrequency",
        "operatingPoints"
    ],
    "$defs": {
        "cllcPowerFlow": {
            "description": "The power flow direction",
            "title": "cllcPowerFlow",
            "type": "string",
            "enum": [
                "Forward",
                "Reverse"
            ]
        },
        "cllcOperatingPoint": {
            "description": "The description of one CLLC operating point",
            "title": "cllcOperatingPoint",
            "type": "object",
            "properties": {
                "outputVoltages": {
                    "description": "A list of output voltages, one per output",
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 1
                },
                "outputVoltagesType": {
                    "description": "Type of value carried in outputVoltages: which aggregate of the periodic waveform the number represents. Defaults to dc. See IEV 103-02.",
                    "type": "string",
                    "enum": [
                        "dc",
                        "rms",
                        "peak",
                        "peakToPeak",
                        "average"
                    ],
                    "default": "dc"
                },
                "outputCurrents": {
                    "description": "A list of output currents, one per output",
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 1
                },
                "outputCurrentsType": {
                    "description": "Type of value carried in outputCurrents: which aggregate of the periodic waveform the number represents. Defaults to dc. See IEV 103-02.",
                    "type": "string",
                    "enum": [
                        "dc",
                        "rms",
                        "peak",
                        "peakToPeak",
                        "average"
                    ],
                    "default": "dc"
                },
                "switchingFrequency": {
                    "description": "The switching frequency of the operating point",
                    "type": "number"
                },
                "powerFlow": {
                    "description": "The power flow direction",
                    "$ref": "#/$defs/cllcPowerFlow"
                },
                "ambientTemperature": {
                    "description": "The ambient temperature of the operating point",
                    "type": "number"
                }
            },
            "required": [
                "outputVoltages",
                "outputCurrents",
                "switchingFrequency",
                "powerFlow",
                "ambientTemperature"
            ]
        }
    }
}
