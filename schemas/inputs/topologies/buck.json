{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/inputs/topologies/buck.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "buck",
    "description": "The description of a Buck converter excitation",
    "type": "object",
    "properties": {
        "inputVoltage": {
            "description": "The input voltage of the buck",
            "$ref": "../../utils.json#/$defs/dimensionWithTolerance"
        },
        "diodeVoltageDrop": {
            "description": "The voltage drop on the diode",
            "type": "number"
        },
        "maximumSwitchCurrent": {
            "description": "The maximum current that can go through the selected switch",
            "type": "number"
        },
        "currentRippleRatio": {
            "description": "The maximum current ripple allowed in the output",
            "type": "number"
        },
        "efficiency": {
            "description": "The target efficiency",
            "type": "number",
            "default": 0.95
        },
        "operatingPoints": {
            "description": "A list of operating points",
            "type": "array",
            "items": {
                "$ref": "#/$defs/buckOperatingPoint"
            },
            "minItems": 1
        }
    },
    "required": [
        "inputVoltage",
        "diodeVoltageDrop",
        "operatingPoints"
    ],
    "$defs": {
        "buckOperatingPoint": {
            "description": "The description of one buck operating point",
            "title": "buckOperatingPoint",
            "$ref": "../../utils.json#/$defs/baseOperatingPoint"
        }
    }
}
