{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/mas/inputs.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "inputs",
    "description": "The description of the inputs that can be used to design a Magnetic",
    "type": "object",
    "properties": {
        "operatingPoints": {
            "description": "Data describing the operating points",
            "title": "operatingPoints",
            "type": "array",
            "items": {
                "$ref": "./inputs/operatingPoint.json"
            },
            "minItems": 1
        },
        "designRequirements": {
            "description": "Data describing the design requirements",
            "title": "designRequirements",
            "$ref": "./inputs/designRequirements.json"
        },
        "converterInformation": {
            "title": "converterInformation",
            "type": "object",
            "properties": {
                "supportedTopologies": {
                    "type": "object",
                    "properties": {
                        "flyback": {
                            "$ref": "./inputs/topologies/flyback.json"
                        },
                        "currentTransformer": {
                            "$ref": "./inputs/topologies/currentTransformer.json"
                        },
                        "isolatedBuck": {
                            "$ref": "./inputs/topologies/isolatedBuck.json"
                        },
                        "isolatedBuckBoost": {
                            "$ref": "./inputs/topologies/isolatedBuckBoost.json"
                        },
                        "buck": {
                            "$ref": "./inputs/topologies/buck.json"
                        },
                        "boost": {
                            "$ref": "./inputs/topologies/boost.json"
                        },
                        "pushPull": {
                            "$ref": "./inputs/topologies/pushPull.json"
                        },
                        "forward": {
                            "$ref": "./inputs/topologies/forward.json"
                        },
                        "dualActiveBridge": {
                            "$ref": "./inputs/topologies/dualActiveBridge.json"
                        },
                        "llcResonant": {
                            "$ref": "./inputs/topologies/llcResonant.json"
                        },
                        "cllcResonant": {
                            "$ref": "./inputs/topologies/cllcResonant.json"
                        },
                        "cllllcResonant": {
                            "$ref": "./inputs/topologies/cllllcResonant.json"
                        },
                        "phaseShiftedFullBridge": {
                            "$ref": "./inputs/topologies/phaseShiftedFullBridge.json"
                        },
                        "phaseShiftedHalfBridge": {
                            "$ref": "./inputs/topologies/phaseShiftedHalfBridge.json"
                        },
                        "powerFactorCorrection": {
                            "$ref": "./inputs/topologies/powerFactorCorrection.json"
                        },
                        "commonModeChoke": {
                            "$ref": "./inputs/topologies/commonModeChoke.json"
                        },
                        "differentialModeChoke": {
                            "$ref": "./inputs/topologies/differentialModeChoke.json"
                        },
                        "asymmetricHalfBridge": {
                            "$ref": "./inputs/topologies/asymmetricHalfBridge.json"
                        },
                        "cuk": {
                            "$ref": "./inputs/topologies/cuk.json"
                        },
                        "sepic": {
                            "$ref": "./inputs/topologies/sepic.json"
                        },
                        "zeta": {
                            "$ref": "./inputs/topologies/zeta.json"
                        },
                        "weinberg": {
                            "$ref": "./inputs/topologies/weinberg.json"
                        },
                        "fourSwitchBuckBoost": {
                            "$ref": "./inputs/topologies/fourSwitchBuckBoost.json"
                        },
                        "seriesResonant": {
                            "$ref": "./inputs/topologies/seriesResonant.json"
                        },
                        "viennaRectifier": {
                            "$ref": "./inputs/topologies/vienna.json"
                        }
                    }
                }
            }
        }
    },
    "required": [
        "operatingPoints",
        "designRequirements"
    ],
    "$defs": {}
}
