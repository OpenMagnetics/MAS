{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.psma.com/mas/conformance/class-B.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "MAS conformance Class B \u2014 Transformer",
    "description": "Conformance bundle for Class B. A document conforms to Class B iff (1) it validates against the base MAS schema, (2) it declares masConformance=\"B\", (3) the magnetic has at least two windings (so primary + secondary, the minimum for a transformer), and (4) the inputs declare both magnetizingInductance and turnsRatios. Class B implementations are expected to handle multi-winding coils, bobbins and insulation requirements. See docs/conformance.md.",
    "allOf": [
        {
            "$ref": "../MAS.json"
        },
        {
            "type": "object",
            "properties": {
                "masConformance": {
                    "const": "B"
                },
                "inputs": {
                    "type": "object",
                    "properties": {
                        "designRequirements": {
                            "type": "object",
                            "required": [
                                "magnetizingInductance",
                                "turnsRatios"
                            ]
                        }
                    },
                    "required": [
                        "designRequirements"
                    ]
                },
                "magnetic": {
                    "type": "object",
                    "properties": {
                        "coil": {
                            "type": "object",
                            "properties": {
                                "functionalDescription": {
                                    "type": "array",
                                    "minItems": 2
                                }
                            },
                            "required": [
                                "functionalDescription"
                            ]
                        }
                    },
                    "required": [
                        "core",
                        "coil"
                    ]
                }
            },
            "required": [
                "masConformance"
            ]
        }
    ]
}
